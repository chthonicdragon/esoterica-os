############################################
# Esoterica OS — Environment Configuration #
############################################

# Supabase (required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# OAuth redirect (required for Sign-in)
# Example: https://your-domain.vercel.app/
VITE_AUTH_REDIRECT_URL=https://your-domain.vercel.app/

# AI providers (set at least one)
# OpenRouter
VITE_OPENROUTER_API_KEY=
# Groq
VITE_GROQ_API_KEY=

# Optional: site info for OpenRouter Referer policy
VITE_SITE_URL=https://your-domain.vercel.app
VITE_SITE_TITLE=Esoterica OS

# AI gateway routing mode:
# - direct  -> call providers directly from the client (default)
# - gateway -> call serverless endpoints /api/openrouter or /api/groq
VITE_AI_GATEWAY_MODE=direct

# Local fallback for Knowledge Graph extraction:
# - set to 1 to enable local heuristic extractor on network errors
VITE_LOCAL_FALLBACK=0

